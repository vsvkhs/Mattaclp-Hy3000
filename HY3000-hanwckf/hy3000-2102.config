CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_mediatek_mt7981_DEVICE_philips_hy3000=y
CONFIG_TARGET_DEVICE_PACKAGES_mediatek_mt7981_DEVICE_philips_hy3000=""
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
##---------下面配置可自行修改-------------
## 主题皮肤
CONFIG_PACKAGE_luci-theme-bootstrap=y
# CONFIG_PACKAGE_luci-theme-design is not set
## 外部插件
CONFIG_PACKAGE_luci-app-adguardhome=y
# CONFIG_PACKAGE_luci-app-oaf is not set
## 内部插件
CONFIG_PACKAGE_luci-app-dockerman=n
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-app-ddns=n
CONFIG_PACKAGE_ddns-scripts=n
CONFIG_PACKAGE_ddns-scripts_aliyun=n
CONFIG_PACKAGE_ddns-scripts-cloudflare=n
CONFIG_PACKAGE_ddns-scripts-cnkuai=n
CONFIG_PACKAGE_ddns-scripts-digitalocean=n
CONFIG_PACKAGE_ddns-scripts-dnspod=n
CONFIG_PACKAGE_ddns-scripts-dnspod-com=n
CONFIG_PACKAGE_ddns-scripts-freedns=n
CONFIG_PACKAGE_ddns-scripts-gandi=n
CONFIG_PACKAGE_ddns-scripts-godaddy=n
CONFIG_PACKAGE_ddns-scripts-noip=n
CONFIG_PACKAGE_ddns-scripts-nsupdate=n
CONFIG_PACKAGE_ddns-scripts-route53=n
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-msd_lite=y
CONFIG_PACKAGE_luci-app-lucky=n
CONFIG_PACKAGE_luci-app-wol=n
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-eqos-mtk=y
CONFIG_PACKAGE_luci-app-upnp=n
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_luci-app-vsftpd=n
CONFIG_PACKAGE_luci-app-zerotier=n
CONFIG_PACKAGE_luci-app-openvpn-server=n
CONFIG_PACKAGE_luci-app-ipsec-vpnserver-manyusers=n
CONFIG_PACKAGE_tailscale=n
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_qrencode=n
CONFIG_PACKAGE_coremark=n
CONFIG_PACKAGE_vim-full=n
CONFIG_PACKAGE_zsh=n
##---------下面默认配置不建议修改-------------
## 使用mtwifi-cfg无线配置
CONFIG_PACKAGE_luci-app-mtwifi-cfg=y
CONFIG_PACKAGE_luci-i18n-mtwifi-cfg-zh-cn=y
CONFIG_PACKAGE_mtwifi-cfg=y
CONFIG_PACKAGE_lua-cjson=y
## 使用新的无线驱动
CONFIG_MTK_MT_WIFI_DRIVER_VERSION_7672=y
CONFIG_MTK_MT_WIFI_MT7981_20240823=y
